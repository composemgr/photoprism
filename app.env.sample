# PhotoPrism environment configuration
# Copy to app.env and adjust values as needed

# Timezone
TZ=America/New_York

# Host/domain
BASE_HOST_NAME=myhost
BASE_DOMAIN_NAME=example.com

# Admin credentials
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# Database (MariaDB)
DB_CREATE_DATABASE_NAME=photoprism
DB_USER_NAME=photoprism
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Email / SMTP
EMAIL_SERVER_HOST=172.17.0.1
EMAIL_SERVER_PORT=587
EMAIL_SERVER_MAIL_FROM=photoprism@example.com
EMAIL_SERVER_LOGIN_NAME=
EMAIL_SERVER_LOGIN_PASS=
